# ── Web app (apps/web) ─────────────────────────────────────────────
# Show the first-visit guided walkthrough modal (true/false).
# Once a visitor clicks "Enter Platform", the modal stays off for
# that browser via localStorage even if this remains true.
VITE_DEMO_MODE=true

# External demo video links (hosted elsewhere — no video code in this repo).
# Each link appears on the marketing page ONLY when its URL is set;
# leave blank to hide that specific link. Links open in a new tab.
VITE_WALKTHROUGH_VIDEO_URL=
VITE_PROMO_FILM_URL=

# ── API scaffold (apps/api) ────────────────────────────────────────
# Port for the placeholder API server (the product is currently
# 100% frontend — this scaffold is ready for future backend work).
API_PORT=5001
