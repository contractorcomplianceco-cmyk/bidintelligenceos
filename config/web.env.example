# Show the first-visit Rose Demo walkthrough modal (true/false).
VITE_DEMO_MODE=true

# Optional hosted demo video links. If promo is blank, the bundled animated
# promo film plays inside the Rose Demo popup.
VITE_WALKTHROUGH_VIDEO_URL=
VITE_PROMO_FILM_URL=

# Backend API base URL (blank = same-origin / Vite proxy in dev).
VITE_API_BASE_URL=
