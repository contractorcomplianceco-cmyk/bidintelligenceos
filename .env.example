# ── Web app (apps/web) ─────────────────────────────────────────────
# Show the first-visit Rose Demo walkthrough modal (true/false).
# Once a visitor clicks "Enter Demo", the modal stays off for that
# browser via localStorage even if this remains true.
VITE_DEMO_MODE=true

# Optional hosted promo video override (.mp4/.webm/.mov).
# If blank, the Rose Demo popup plays the bundled animated promo film.
VITE_PROMO_FILM_URL=
VITE_WALKTHROUGH_VIDEO_URL=

# Backend API base URL for future fetch calls.
# Dev: leave blank — Vite proxies /api to the local API on :5001.
# Prod: leave blank when the API serves the built SPA on the same host,
#       or set explicitly (e.g. https://api.yourdomain.com).
VITE_API_BASE_URL=

# ── API server (apps/api) ──────────────────────────────────────────
# Port for the API (also used as the production server port).
API_PORT=5001

# Bind address (0.0.0.0 for AWS/EC2).
HOST=0.0.0.0

# Set to production when running `npm run start` on AWS.
NODE_ENV=development

# Optional CORS origin when web and API run on different hosts in dev.
# CORS_ORIGIN=http://localhost:5173

# Auth — required in production
SESSION_SECRET=change-me-in-production

# SQLite data directory (default: <repo>/data/) — used when DATABASE_URL is unset
# DATA_DIR=/var/lib/bid-intelligence-os
# SQLITE_PATH=/var/lib/bid-intelligence-os/bios.db

# Postgres (production). When set, API uses Postgres + org_id RLS instead of SQLite.
# DATABASE_URL=postgresql://bid_intelligence_app:PASSWORD@127.0.0.1:5432/bid_intelligence

# Uploaded bid documents (PDF/TXT/DOCX) — server-only, never sent to browser raw.
# BIOS_UPLOADS_DIR=/var/lib/bid-intelligence-os/uploads

# Research Hub export-ready bridge (server-only).
# Leave blank on the shared AWS box to read from Research Hub's local env file.
# Set explicitly when moving BidIntelligenceOS to a different server.
# RESEARCH_HUB_ENV_FILE=/home/ubuntu/projects/cca-research-hub/web/.env.local
# RESEARCH_HUB_SUPABASE_URL=
# RESEARCH_HUB_SUPABASE_SERVICE_ROLE_KEY=

# Optional ROSEOS AI narrative enhancement (gpt-4o-mini). Rules engine runs without this.
# BIOS_OPENAI_API_KEY=
# BIOS_OPENAI_MODEL=gpt-4o-mini

# Audit engine compliance pull (Audit-Risk-Model API — server-only)
# AUDIT_ENGINE_API_URL=http://127.0.0.1:8080
# AUDIT_ENGINE_API_TOKEN=

# Smoke-test password for scripts/smoke-team-url.mjs and scripts/seed-smoke-users.mjs.
# Set in local .env only — never commit real values.
BIOS_SMOKE_PASSWORD=

# ── Shared CCA auth (Clerk) — optional; legacy JWT remains when unset ─────────
# AUTH_ENABLED=true
# CLERK_SECRET_KEY=sk_live_...
# CLERK_PUBLISHABLE_KEY=pk_live_...
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
# ADMIN_EMAILS=owner@example.com,admin@example.com

# ── Object storage for multi-server deploys (optional; local disk when unset) ─
# BIOS_S3_BUCKET=cca-bid-intelligence-uploads
# BIOS_S3_REGION=us-east-1
# BIOS_S3_PREFIX=bios
# AWS_ACCESS_KEY_ID=   # or use instance role on EC2
# AWS_SECRET_ACCESS_KEY=

# Health monitor alert email uses shared CCA uptime settings by default.
