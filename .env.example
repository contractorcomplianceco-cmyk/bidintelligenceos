# ── Web app (apps/web) ─────────────────────────────────────────────
# Show the first-visit Rose Demo walkthrough modal (true/false).
# Once a visitor clicks "Enter Demo", the modal stays off for that
# browser via localStorage even if this remains true.
VITE_DEMO_MODE=true

# Promo video override (.mp4/.webm/.mov). Default expects:
#   apps/web/public/promo/promo-video.mp4  (NOT in repo — must be uploaded)
# Audio-only fallback exists at /promo/composite_audio.mp3 when video is missing.
VITE_PROMO_FILM_URL=
VITE_WALKTHROUGH_VIDEO_URL=

# Backend API base URL for future fetch calls.
# Dev: leave blank — Vite proxies /api to the local API on :5001.
# Prod: leave blank when the API serves the built SPA on the same host,
#       or set explicitly (e.g. https://api.yourdomain.com).
VITE_API_BASE_URL=

# ── API server (apps/api) ──────────────────────────────────────────
# Port for the API (also used as the production server port).
API_PORT=5001

# Bind address (0.0.0.0 for AWS/EC2).
HOST=0.0.0.0

# Set to production when running `npm run start` on AWS.
NODE_ENV=development

# Optional CORS origin when web and API run on different hosts in dev.
# CORS_ORIGIN=http://localhost:5173
