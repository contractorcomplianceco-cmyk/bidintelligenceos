# ── Web app (apps/web) ─────────────────────────────────────────────
# Show the demo entry modal when visitors click "Launch Demo" (true/false).
# Once a visitor clicks "Enter Demo", the modal stays off for that
# browser via localStorage even if this remains true.
VITE_DEMO_MODE=true

# Narrated product walkthrough video (hosted externally).
# The "Watch Walkthrough" buttons appear ONLY when this URL is set;
# leave blank to hide them. Opens in a new tab.
VITE_WALKTHROUGH_VIDEO_URL=

# Cinematic promo film. Leave blank to use the default local file at
# apps/web/public/promo/promo-video.mp4 (upload the real video there).
# Until that file exists, the demo modal offers a temporary audio
# preview (apps/web/public/promo/composite_audio.mp3) instead.
# Set this to a hosted URL (YouTube, Vimeo, or a direct video link)
# to override the local file.
VITE_PROMO_FILM_URL=

# ── API scaffold (apps/api) ────────────────────────────────────────
# Port for the placeholder API server (the product is currently
# 100% frontend — this scaffold is ready for future backend work).
API_PORT=5001
